# Copy to .env.local (for local dev) and paste into Vercel project env vars (for prod).

# ── Auth ─────────────────────────────────────────────────────────────
# Any random long string. Rotate to invalidate all existing sessions.
JWT_SECRET=change-me-to-a-long-random-string

# ── Email (Resend) ───────────────────────────────────────────────────
# Get free key at https://resend.com (3k emails/mo free).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxx

# Use Resend's sandbox sender for dev (no domain setup needed).
# For production you'll verify your own domain and use something like "FluxBid <no-reply@yourdomain.com>".
EMAIL_FROM=FluxBid <onboarding@resend.dev>

# ── App URL ──────────────────────────────────────────────────────────
# Used for building verification links in emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000
